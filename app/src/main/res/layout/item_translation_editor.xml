<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_translation_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/card_bg"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Top Row: Checkbox (Multi-selection), Key Name, Type, and Status Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/cb_select"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:buttonTint="@color/accent_color"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tv_resource_key"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="app_name"
                android:textColor="@color/accent_color"
                android:textSize="13sp"
                android:textStyle="bold"
                android:ellipsize="middle"
                android:singleLine="true" />

            <!-- Type Badge (e.g., string, plural, array) -->
            <TextView
                android:id="@+id/tv_resource_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_secondary_button"
                android:paddingStart="6dp"
                android:paddingTop="2dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                android:text="string"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />

            <!-- Status Badge (e.g., translated, edited, pending) -->
            <TextView
                android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/accent_color_translucent"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingEnd="8dp"
                android:paddingBottom="2dp"
                android:text="مترجم"
                android:textColor="@color/accent_color"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/divider"
            android:layout_marginBottom="8dp" />

        <!-- Original Text Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="النص الأصلي (English):"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tv_original_char_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="الحروف: 8"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />
            </RelativeLayout>

            <!-- Original Text Frame (Protects placeholders from click or copy) -->
            <TextView
                android:id="@+id/tv_original_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="#19FFFFFF"
                android:padding="8dp"
                android:text="Settings"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textIsSelectable="true"
                android:layoutDirection="ltr"
                android:textAlignment="viewStart" />
        </LinearLayout>

        <!-- Translation Edit Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="التعريب والترجمة (العربية):"
                    android:textColor="@color/accent_color"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_translation_char_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="الحروف: 9"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />
            </RelativeLayout>

            <!-- Editable Translation Box -->
            <EditText
                android:id="@+id/et_translation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_edit_text"
                android:minHeight="44dp"
                android:padding="8dp"
                android:hint="أدخل الترجمة هنا..."
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:layoutDirection="rtl"
                android:textAlignment="viewStart"
                android:scrollbars="vertical" />
        </LinearLayout>

        <!-- Dynamic Placeholder/HTML Warning indicator -->
        <LinearLayout
            android:id="@+id/layout_warnings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#22FF5252"
            android:padding="6dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/stat_sys_warning"
                app:tint="@color/error"
                android:contentDescription="تحذير" />

            <TextView
                android:id="@+id/tv_warning_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="تنبيه: علامات التنسيق (Placeholders) لا تتطابق مع النص الأصلي!"
                android:textColor="@color/error"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Row Actions Bar (Compact & Sleek) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Translate button -->
            <ImageButton
                android:id="@+id/btn_row_translate"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_translate"
                app:tint="@color/accent_color"
                android:contentDescription="ترجمة بالذكاء الاصطناعي" />

            <!-- Copy original text -->
            <ImageButton
                android:id="@+id/btn_row_copy_original"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_copy"
                app:tint="@color/text_secondary"
                android:contentDescription="نسخ النص الأصلي" />

            <!-- Copy translation text -->
            <ImageButton
                android:id="@+id/btn_row_copy_translation"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_share"
                app:tint="@color/text_secondary"
                android:contentDescription="نسخ الترجمة" />

            <!-- Paste button -->
            <ImageButton
                android:id="@+id/btn_row_paste"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_paste"
                app:tint="@color/text_secondary"
                android:contentDescription="لصق" />

            <!-- Undo button -->
            <ImageButton
                android:id="@+id/btn_row_undo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_undo"
                app:tint="@color/text_secondary"
                android:contentDescription="تراجع" />

            <!-- Redo button -->
            <ImageButton
                android:id="@+id/btn_row_redo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_redo"
                app:tint="@color/text_secondary"
                android:contentDescription="إعادة تراجع" />

            <!-- Reset button -->
            <ImageButton
                android:id="@+id/btn_row_reset"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/warning"
                android:contentDescription="إعادة تعيين" />

            <!-- Clear button -->
            <ImageButton
                android:id="@+id/btn_row_clear"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_clear"
                app:tint="@color/error"
                android:contentDescription="مسح" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <!-- Bookmark toggle -->
            <ImageButton
                android:id="@+id/btn_row_bookmark"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_bookmark"
                app:tint="@color/text_secondary"
                android:contentDescription="تفضيل" />

            <!-- Expand/Collapse arrow -->
            <ImageButton
                android:id="@+id/btn_row_expand_toggle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_expand"
                app:tint="@color/text_primary"
                android:contentDescription="تفاصيل إضافية" />
        </LinearLayout>

        <!-- Expanded Details View (Visible only when expanded) -->
        <LinearLayout
            android:id="@+id/layout_expanded_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0AFFFFFF"
            android:padding="8dp"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="معلومات المورد المتقدمة:"
                android:textColor="@color/accent_color"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="4"
                android:alignmentMode="alignBounds">

                <!-- File Path -->
                <TextView
                    android:id="@+id/tv_detail_file_path"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="المسار: /res/values/strings.xml"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginBottom="4dp" />

                <!-- Line Number -->
                <TextView
                    android:id="@+id/tv_detail_line_number"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="رقم السطر: 45"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginBottom="4dp" />

                <!-- Resource ID -->
                <TextView
                    android:id="@+id/tv_detail_resource_id"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="معرف المورد (ID): 0x7f100010"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginBottom="4dp" />

                <!-- Comments -->
                <TextView
                    android:id="@+id/tv_detail_comments"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="التعليقات: تسمية توضيحية للمشروع"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginBottom="4dp" />

                <!-- Has HTML indicator -->
                <TextView
                    android:id="@+id/tv_detail_has_html"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="يحتوي على HTML: لا"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginBottom="4dp" />

                <!-- Has Placeholder indicator -->
                <TextView
                    android:id="@+id/tv_detail_has_placeholder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="يحتوي علامات تنسيق: لا"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginBottom="4dp" />

                <!-- Plural details -->
                <TextView
                    android:id="@+id/tv_detail_plural_qty"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="نوع الجمع: N/A"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:visibility="gone" />

                <!-- Array Index details -->
                <TextView
                    android:id="@+id/tv_detail_array_idx"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:text="فهرس المصفوفة: -1"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </GridLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
