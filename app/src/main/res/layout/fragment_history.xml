<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_bg"
    android:padding="@dimen/spacing_medium">

    <!-- History List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_history"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        tools:listitem="@layout/item_history" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/empty_history_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_large"
        android:visibility="visible">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_empty_history"
            android:contentDescription="@string/empty_history_title" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_large"
            android:text="@string/empty_history_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_title_medium"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            android:gravity="center"
            android:text="@string/empty_history_desc"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_body_medium" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_choose_file_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_huge"
            android:text="@string/action_btn_choose_file"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_body_medium"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_color"
            app:cornerRadius="@dimen/button_corner_radius"
            app:icon="@drawable/ic_file"
            app:iconGravity="textStart" />

    </LinearLayout>

</FrameLayout>
